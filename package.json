{
  "name": "plan-vault",
  "private": true,
  "version": "1.0.0",
  "description": "Plan Vault — Decentralized Trading Diary on Solana",
  "scripts": {
    "install:all": "pnpm --dir anchor_project install && pnpm --dir frontend install",
    "build:program": "pnpm --dir anchor_project build",
    "test:program": "pnpm --dir anchor_project test",
    "dev": "pnpm --dir frontend dev",
    "dev:worker": "pnpm --dir workers dev",
    "dev:validator": "solana-test-validator",
    "dev:db:init": "pnpm --dir workers db:local",
    "dev:db:reset": "rm -rf workers/.wrangler/state/v3/d1 && pnpm dev:db:init",
    "dev:db:migrate": "pnpm --dir workers db:migrate",
    "build:frontend": "NODE_OPTIONS='--no-warnings' pnpm --dir frontend build",
    "build": "pnpm build:program && pnpm build:frontend",
    "lint": "pnpm --dir frontend lint",
    "format": "pnpm --dir frontend format",
    "format:check": "pnpm --dir frontend format:check",
    "ci": "pnpm install:all && pnpm build:program && pnpm test:program && pnpm lint && pnpm format:check && pnpm build:frontend"
  }
}
